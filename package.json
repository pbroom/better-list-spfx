{
  "name": "better-list-spfx",
  "version": "0.1.11",
  "private": true,
  "license": "MIT",
  "engines": {
    "node": ">=22.14.0 <23.0.0"
  },
  "main": "lib/index.js",
  "scripts": {
    "build": "heft test --clean --production && node scripts/verify-monaco-css.mjs && heft package-solution --production",
    "clean": "heft clean",
    "generate:group-icons": "node scripts/generate-group-icon-catalogs.mjs",
    "release:prepare": "node scripts/release-artifacts.mjs prepare",
    "release:verify": "node scripts/release-artifacts.mjs verify",
    "test": "heft test",
    "test:release": "node --test scripts/release-artifacts.test.mjs",
    "serve": "heft start --clean",
    "start": "heft start --clean",
    "ship": "heft test --clean --production && node scripts/verify-monaco-css.mjs && node scripts/copy-monaco-assets.mjs --app . && node scripts/copy-eb-garamond-assets.mjs --app . && heft package-solution --production && node scripts/verify-eb-garamond-build.mjs --app .",
    "version:check": "node scripts/sync-spfx-version.mjs --check",
    "version:sync": "node scripts/sync-spfx-version.mjs",
    "eject-webpack": "heft eject-webpack"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fluentui/react-components": "9.74.3",
    "@fluentui/react-icons": "2.0.330",
    "@fontsource-variable/eb-garamond": "5.3.0",
    "@fontsource-variable/geist-mono": "5.3.0",
    "@iconify/react": "^4.1.1",
    "@microsoft/sp-component-base": "1.23.2",
    "@microsoft/sp-core-library": "1.23.2",
    "@microsoft/sp-http": "1.23.2",
    "@microsoft/sp-lodash-subset": "1.23.2",
    "@microsoft/sp-office-ui-fabric-core": "1.23.2",
    "@microsoft/sp-property-pane": "1.23.2",
    "@microsoft/sp-webpart-base": "1.23.2",
    "monaco-editor": "0.55.1",
    "react": "17.0.1",
    "react-dom": "17.0.1",
    "tslib": "2.3.1"
  },
  "devDependencies": {
    "@iconify-json/fluent": "^1.2.53",
    "@iconify-json/fluent-color": "^1.2.21",
    "@iconify-json/solar": "^1.2.5",
    "@microsoft/eslint-config-spfx": "1.23.2",
    "@microsoft/eslint-plugin-spfx": "1.23.2",
    "@microsoft/sp-module-interfaces": "1.23.2",
    "@microsoft/spfx-heft-plugins": "1.23.2",
    "@microsoft/spfx-web-build-rig": "1.23.2",
    "@rushstack/heft": "1.2.17",
    "@types/jest": "30.0.0",
    "@types/react": "17.0.45",
    "@types/react-dom": "17.0.17",
    "@types/webpack-env": "~1.15.2",
    "css-loader": "~7.1.2",
    "eslint": "9.37.0",
    "eslint-plugin-react-hooks": "5.2.0",
    "typescript": "~5.8.0"
  },
  "overrides": {
    "@rushstack/heft": "1.2.17"
  },
  "resolutions": {
    "@types/react": "17.0.45"
  }
}
